# Telegram Bot Token dari @BotFather
BOT_TOKEN=123456:ABCDEF_GANTI_DENGAN_TOKEN_BOT

# User ID owner utama bot. Pisahkan dengan spasi jika lebih dari satu.
OWNER=123456789

# Admin tetap dari config.env. Pisahkan dengan spasi jika lebih dari satu.
ADMINS=123456789 987654321

# Channel database/log bot. Bot wajib menjadi admin di channel ini.
CHANNEL_DB=-1001234567890

# MongoDB
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=fsub_bot

# Force subscribe wajib dari config.env.
# Dua FSUB ini tidak bisa dihapus lewat /delsub.
FORCE_SUB_1=-1001111111111
FORCE_SUB_2=-1002222222222

# Proteksi konten file yang dikirim bot.
RESTRICT=True

# Default teks tombol join. Owner bisa ubah runtime dengan /setjoin teks_baru
BUTTON_TITLE=ᴊᴏɪɴ
BUTTON_ROW=2

START_MESSAGE=Halo {mention}!\n\nSaya dapat menyimpan file pribadi di Channel tertentu dan pengguna lain dapat mengaksesnya dari link khusus.

# Default FORCE_MESSAGE. Owner bisa ubah runtime dengan /setforce pesan_baru
# Placeholder: {first}, {last}, {username}, {mention}, {id}
FORCE_MESSAGE=Halo {mention}!\n\nHayolo Ketahuan Belum Join Channel dan Groupnya Yaa, Yuk Join Dulu Biar Bisa Buka Linknya.\n\nSilakan Join Ke Channel dan Groupnya di Bawah Ini Terlebih Dahulu Yaa.

# Opsional
CUSTOM_CAPTION=
DISABLE_BUTTON=False
